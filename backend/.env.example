# ===== 后端环境变量 =====
# 复制本文件为 backend/.env 并填入真实值

# ModelScope API 配置（AI 设计生成 / 款式分析 / 肤色分析）
# 获取方式：https://modelscope.cn/my/myaccesstoken
# 使用 Qwen3-VL-30B-A3B-Instruct 多模态模型
MODELSCOPE_TOKEN=your-modelscope-token-here

# Supabase / Postgres 数据库连接（账号系统、收藏、我的设计、个人资料）
# Supabase 控制台 → Project Settings → Database → Connection string → URI（选 Session pooler）
# 密码里若含特殊字符（+ & $ 等）需做 URL 编码
DATABASE_URL=postgresql://postgres.xxxxx:your-password@aws-x-xxx.pooler.supabase.com:5432/postgres
